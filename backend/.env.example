# PantryPal Backend Configuration
# Copy this file to .env and fill in your values

# AI Provider(s) for recipe PDF parsing
# Single provider: "gemini" or "groq" or "claude"
# Multiple providers (fallback order): "gemini,groq" - tries gemini first, then groq
AI_PROVIDER=gemini,groq

# API Keys - comma-separated for multiple keys that auto-rotate on rate limit
# Example: GEMINI_API_KEYS=key1,key2,key3

# Gemini (free tier: https://aistudio.google.com/app/apikey)
GEMINI_API_KEYS=your_key1,your_key2

# Groq (free tier: https://console.groq.com/keys)
GROQ_API_KEYS=your_key1,your_key2

# Anthropic/Claude (paid: https://console.anthropic.com/)
# ANTHROPIC_API_KEYS=your_key

# Single key format also works:
# GEMINI_API_KEY=your_single_key
# GROQ_API_KEY=your_single_key
